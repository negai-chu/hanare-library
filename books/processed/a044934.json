    {
      "pageNumber": 2,
      "content": "　ギツコン\n\nバツタン\n\n　　あがつた\n\n　　あがつた。\n\nギツコン\n\nバツタン\n\n　　さがつた\n\n　　さがつた。\n\nギツコン",
      "characters": 63,
      "ruby": []
    },
    {
      "pageNumber": 3,
      "content": "バツタン\n\n　　そら　そら\n\n　　あたしよ。\n\nギツコン\n\nバツタン\n\n　　こんどは\n\n　　ぼくだよ。\n\nギツコン\n\nバツタン",
      "characters": 63,
      "ruby": []
    },
    {
      "pageNumber": 4,
      "content": "　　はやく\n\n　　こがぬと\n\nギツコン\n\nバツタン\n\n　　米つき　ばつたに\n\n　　わらはれる。",
      "characters": 47,
