  "content": [
    {
      "pageNumber": 1,
      "content": "朝おき雀",
      "characters": 4,
      "ruby": [],
      "displayType": "book-title"
    },
    {
      "pageNumber": 2,
      "content": "　七ツニナレバ\n\n　オシヨウガツ　キタヨ\n\nコンドハ　イクツ\n\nコンドハ　六ツ\n\nキヨネンハ　五ツ\n\n七ツニ　ナレバ\n\nガツカウヘ　イクヨ\n\nランドセル　シヨツテ\n\nゴホンヲ　イレテ\n\nアミアゲ　ハイテ",
      "characters": 101,
      "ruby": []
    },
    {
      "pageNumber": 3,
      "content": "ボウシヲ　カブリ\n\nオテテヲ　フツテ\n\nヒトリデ　イクヨ神詣",
      "characters": 30,
      "ruby": []
    },
    {
      "pageNumber": 4,
      "content": "年の初めの\n\n神まゐり\n\nお手々合はせて\n\nお社に\n\nみ国の栄え\n\n心から\n\n神にお願ひ\n\nかけました\n\n空もしづかに",
      "characters": 59,
      "ruby": []
    },
    {
      "pageNumber": 5,
      "content": "ほのぼのと\n\nすがすがしくも\n\n明けていく年賀状お友達から年賀状",
      "characters": 32,
      "ruby": []
    },
    {
      "pageNumber": 6,
      "content": "字まで正しく\n\n丁寧に\n\n明けて新年\n\nお目出たう\n\n大きく書いて\n\nその次に\n\n優等生に\n\nなるやうに\n\n僕も今年は",
      "characters": 59,
      "ruby": []
    },
    {
      "pageNumber": 7,
      "content": "去年より\n\n勉強しますと\n\n書いてある田舎の正月",
      "characters": 24,
      "ruby": []
    },
    {
      "pageNumber": 8,
      "content": "田舎の正月ア\n\n長閑《のどか》だナ\n\n豊年祭りも\n\nもうすんだ\n\n畑の仕事も\n\n皆了へた\n\n田甫《たんぼ》の仕事も\n\n皆了へた\n\nどの家も俵は",
      "characters": 71,
      "ruby": []
    },
    {
      "pageNumber": 9,
      "content": "積んである\n\n村中　にこにこ\n\nむつましい\n\n山でも　森でも\n\nほほえんだ\n\n軒端にや朝から\n\n日が当り\n\n鶏　雄鶏\n\n遊んでる",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 10,
      "content": "厩《うまや》の馬まで\n\n気楽だナ初夢",
      "characters": 18,
      "ruby": []
    },
    {
      "pageNumber": 11,
      "content": "正月二日ノ\n\nハツユメニ\n\n　　　エンヤラヤ\n\n　　　ギツチラコ\n\nイソイデ　コイコイ\n\nタカラブネ\n\n　　　ギツチラコ\n\n　　　エンヤラヤ\n\nタカラヲ　ヤマホド",
      "characters": 81,
      "ruby": []
    },
    {
      "pageNumber": 12,
      "content": "ツンデ　コイ\n\n　　　エンヤラヤ\n\n　　　ギツチラコ\n\nイソイデ　コイコイ\n\nタカラブネ万歳さん",
      "characters": 48,
      "ruby": []
    },
    {
      "pageNumber": 13,
      "content": "お正月は\n\n目出たいな\n\n万歳《まんざい》さんは\n\n目出たいな\n\n鼓《つづみ》を叩いて\n\nポンポン　ポン\n\nお伴《とも》の才蔵も\n\n目出たいな\n\nニコニコ　ニツコリ",
      "characters": 82,
      "ruby": []
    },
    {
      "pageNumber": 14,
      "content": "目出たいな\n\n頭巾をかぶつて\n\n笑ひ顔\n\n鼓を叩いて\n\nポンポン　ポン凧あげと羽根つき",
      "characters": 43,
      "ruby": []
    },
    {
      "pageNumber": 15,
      "content": "風吹け　風吹け\n\n早く吹け\n\n海から山から\n\n青空に\n\n凧あげするから\n\n風よ吹け\n\n羽根つきするから\n\n風吹くな\n\nお庭にお屋根に",
      "characters": 66,
      "ruby": []
    },
    {
      "pageNumber": 16,
      "content": "青空に\n\n羽根つきするから\n\n風吹くな豆マキ福ハ　オウチニ\n\n鬼ハ　ソト豆マキ　パラパラ",
      "characters": 44,
      "ruby": []
    },
    {
      "pageNumber": 17,
      "content": "パァラ　パラ\n\n鬼ハ　ビックリ\n\n大サワギ\n\n豆ニハ　カナハン\n\nタイヘン　ダ\n\n福ハ　オウチデ\n\nニツコ　ニコ\n\nソレ　マケ　ソレ　マケ\n\nモツト　マケ豆マキ　パラパラ",
      "characters": 85,
      "ruby": []
    },
    {
      "pageNumber": 18,
      "content": "パァラ　パラ\n\n鬼ハ　アワテテ\n\nエツサツサ初午の太鼓",
      "characters": 27,
      "ruby": []
    },
    {
      "pageNumber": 19,
      "content": "初午だ\n\n　　　初午だ\n\nドドンカドン\n\n　　　ドドンカドン\n\nお稲荷さまの\n\n　　　お祭りだ\n\nドドンカドン\n\n　　　ドドンカドン\n\nみんな来い来い",
      "characters": 75,
      "ruby": []
    },
    {
      "pageNumber": 20,
      "content": "　　　早く来い\n\n狐のお面が\n\n　　　はじまつたお雛さまいつでも　やさしいお雛さま",
      "characters": 41,
      "ruby": []
    },
    {
      "pageNumber": 21,
      "content": "今年も来ました\n\nおそろひで\n\nお口も　きかずに\n\nおとなしく\n\nきちんと　ならんで\n\nお上品\n\n去年は　白酒《しろざけ》\n\nあげました\n\n今年も　白酒",
      "characters": 76,
      "ruby": []
    },
    {
      "pageNumber": 22,
      "content": "あげましよか\n\n緋桃《ひもも》も　綺麗に\n\n咲いてます\n\nお遊び下さいお雛さま春ノ兎アソビ",
      "characters": 45,
      "ruby": []
    },
    {
      "pageNumber": 23,
      "content": "ミンナ　コイコイ\n\nハヤク　コイ\n\nハルハ　タノシク\n\nゲンキヨク\n\nウサギ　アソビヲ\n\nイタシマセウ\n\nオニハデ　ピヨン　ピヨン\n\nハネナガラ\n\nグルグル　マハツテ",
      "characters": 83,
      "ruby": []
    },
    {
      "pageNumber": 24,
      "content": "オモシロク\n\nピヨンピヨン　ハネハネ\n\nアソビマセウ一年生ボウシモ　オクツモ\n\nアタラシク\n\nイヨイヨ　ケフカラ一年生",
      "characters": 59,
      "ruby": []
    },
    {
      "pageNumber": 25,
      "content": "マイアサ　ガツカウヘ\n\nマヰリマス\n\nオウチヘ　カヘレバ\n\nタダイマト\n\nガツカウノ　オハナシ\n\nイタシマスおはやうおはやう　おはやう",
      "characters": 67,
      "ruby": []
    },
    {
      "pageNumber": 26,
      "content": "今日《こんにち》は\n\nお靴も　ひとりで\n\nはきました\n\n歩けば　キツキと\n\n鳴りました\n\nみなさん　おはやう\n\n今日は\n\n唱歌も　元気に\n\n歌ひます",
      "characters": 74,
      "ruby": []
    },
    {
      "pageNumber": 27,
      "content": "楽しい　遊びも\n\nいたしませう土筆ノ行列",
      "characters": 20,
      "ruby": []
    },
    {
      "pageNumber": 28,
      "content": "ツンツン　ツクツク\n\nツクシンボ\n\nツンツン　土筆《ツクシ》ハ\n\n原ツパニ\n\nツクツク並ンデ\n\n立ツテマス\n\n帽子モ揃ヒノ\n\n帽子　デス\n\n袴モ揃ヒノ",
      "characters": 75,
      "ruby": []
    },
    {
      "pageNumber": 29,
      "content": "袴デス\n\nツクツク　ツンツン\n\nツクシンボ\n\nコツチヲ向イタラ\n\n向イタキリ\n\nアツチヲ向イタラ\n\n向イタキリ\n\nツンツン並ンデ\n\n原ツパニ",
      "characters": 70,
      "ruby": []
    },
    {
      "pageNumber": 30,
      "content": "ツンツン　ツクツク\n\n立ツテマス春が呼ぶ畑の中から春が呼ぶ春は菜種の\n\n花を呼ぶ\n\n菜種も呼ばれて\n\n花が咲き\n\n野原の中から春が呼ぶ春は菫の\n\n花を呼ぶ\n\n菫も呼ばれて\n\n花が咲く潮干狩",
      "characters": 94,
      "ruby": []
    },
    {
      "pageNumber": 31,
      "content": "ハダシデ　ピチヤ　ピチヤ\n\nシホヒガリ\n\nハマグリ　アサリハ\n\nスナノ　ナカ\n\nコガニハ　チヨロ　チヨロ\n\nニゲマハル\n\nチヨロ　チヨロ　コガニガ\n\nニゲルノヲ\n\nハマグリ　アサリヲ",
      "characters": 91,
      "ruby": []
    },
    {
      "pageNumber": 32,
      "content": "フミナガラ\n\nハダシデ　ピチヤ　ピチヤ\n\nオヒアルク汐干狩友と連れ立ち汐干狩",
      "characters": 38,
      "ruby": []
    },
    {
      "pageNumber": 33,
      "content": "汐干の渚や\n\n遠浅に\n\n拾ふ小さな\n\n貝の数\n\n月の数ほど\n\n打つ波に\n\n汐干の渚も\n\n汐は満ち\n\nいつかあたりは海となるチンチン電車チンチン電車",
      "characters": 73,
      "ruby": []
    },
    {
      "pageNumber": 34,
      "content": "チン電車\n\nチンチン鳴らして\n\nとまりますチンチン電車チン電車チンチン電車ならびます\n\nあれあれ電車\n\nあの電車\n\n電車と電車が\n\nつづきます春の風",
      "characters": 74,
      "ruby": []
    },
    {
      "pageNumber": 35,
      "content": "みんな　出て来い\n\n日の丸持つて\n\n春が　来た来た\n\n愉快だナ\n\nひろい野原に\n\n大空に\n\n吹く春風は\n\n愉快だナ\n\n手には　日の丸",
      "characters": 66,
      "ruby": []
    },
    {
      "pageNumber": 36,
      "content": "ひらひら　国旗\n\n春が　来た来た\n\n愉快だナ\n\n靴も軽《か》る軽る\n\n帽子に旗に\n\n吹く春風は\n\n愉快だナ春の田の中",
      "characters": 58,
      "ruby": []
    },
    {
      "pageNumber": 37,
      "content": "田甫《たんぼ》の　田の中\n\n春になり\n\n泥田に　寝てゐた\n\n田螺《たにし》さへ\n\n朝から　出て来て\n\n遊んでる\n\n　　　氷が張るから\n\n　　　寒いから\n\n　　　田螺は冬より",
      "characters": 86,
      "ruby": []
    },
    {
      "pageNumber": 38,
      "content": "　　　春が好き\n\n田甫の　田の中\n\n春になり\n\n蛙も\n\n目を覚まし\n\n朝から　元気で\n\n遊んでる\n\n　　　蛙も鰌《どじよう》も\n\n　　　春が好き",
      "characters": 72,
      "ruby": []
    },
    {
      "pageNumber": 39,
      "content": "　　　田螺と一緒に\n\n　　　出てあるく森で啼く鳥",
      "characters": 24,
      "ruby": []
    },
    {
      "pageNumber": 40,
      "content": "森の　森の\n\n真ン中\n\n背高《せいたか》のつぽの\n\n杉の木に\n\n春に　なると\n\n鳥が\n\nチンカラ　チンと\n\nとまる\n\n何んと啼いた",
      "characters": 65,
      "ruby": []
    },
    {
      "pageNumber": 41,
      "content": "鳥だ\n\n青空　見てゐて\n\n啼く鳥だ\n\n杉に　ちやんと\n\nとまり\n\nチンカラ　チンと\n\n啼いた春の空",
      "characters": 49,
      "ruby": []
    },
    {
      "pageNumber": 42,
      "content": "空は奇麗に\n\n晴れてゐる\n\n毎日　毎日\n\nよい天気\n\n遠くの山も\n\nよく見えた\n\n山の上まで\n\n雪が解け\n\n小藪で囀《さへづ》る",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 43,
      "content": "鶯に\n\nうれしい　うれしい\n\n春が来た菜の花とまれよ　とまれ\n\n蝶々よ　とまれ\n\n畑の　中の\n\n菜の葉の　上に\n\n蝶々の　すきな菜の花　咲いた",
      "characters": 71,
      "ruby": []
    },
    {
      "pageNumber": 44,
      "content": "咲いたよ　咲いた\n\nきれいな　花が\n\n菜の葉の　上に\n\nヒラヒラ　ヒラと\n\n蝶々よ　とまれ菜の花　咲いた桜と小鳥",
      "characters": 56,
      "ruby": []
    },
    {
      "pageNumber": 45,
      "content": "山にも　里にも\n\n春が来た\n\n小鳥の　お母さん\n\n春が好き\n\nツーピー　ツーピー\n\nツーピツピツ\n\n小鳥のお母さん\n\n花も好き\n\n花では　桜の",
      "characters": 71,
      "ruby": []
    },
    {
      "pageNumber": 46,
      "content": "花が好き\n\nツーピー　ツーピー\n\nツーピツピツ\n\n山にも　桜の\n\n花が咲き\n\n里でも　桜の\n\n花が咲く\n\nツーピー　ツーピー\n\nツーピツピツ学校の前",
      "characters": 74,
      "ruby": []
    },
    {
      "pageNumber": 47,
      "content": "学校の前は\n\n畑です\n\n畑の菜の花\n\n咲くころに\n\nわたしは入学\n\nしたのです\n\nそれから今日は\n\n一年目\n\n今年も菜の花",
      "characters": 61,
      "ruby": []
    },
    {
      "pageNumber": 48,
      "content": "咲きました\n\nわたしは二年に\n\nなりました\n\n畑に菜の花\n\n咲くたびに\n\n毎年　進級\n\nいたします桜花咲く",
      "characters": 53,
      "ruby": []
    },
    {
      "pageNumber": 49,
      "content": "咲いて　見事に\n\nひらひらと\n\n散るも勇まし\n\n桜花\n\n桜の花は\n\nいさざよき\n\nわが日本の\n\nほこりなり\n\n頃も弥生の",
      "characters": 60,
      "ruby": []
    },
    {
      "pageNumber": 50,
      "content": "春に咲き\n\n富士の高嶺も\n\nうららかに\n\n人の心も\n\nのびのびと\n\n勇まし　ゆかし\n\n限りなく\n\n花の吹雪と\n\nやがて散る",
      "characters": 61,
      "ruby": []
    },
    {
      "pageNumber": 51,
      "content": "国のほこりの\n\n桜花田螺の泥遊び",
      "characters": 16,
      "ruby": []
    },
    {
      "pageNumber": 52,
      "content": "田甫《たんぼ》の　田螺《たにし》は\n\n泥だらけ\n\nお顔が　どこだか\n\nわからない\n\nお目々も　どこだか\n\nわからない\n\nお顔も　お目々も\n\n泥だらけ\n\nたんたん　田螺は",
      "characters": 84,
      "ruby": []
    },
    {
      "pageNumber": 53,
      "content": "田の中に\n\n朝から　晩まで\n\n泥遊び\n\nあつちへ　転げて\n\nどつこいしよ\n\nこつちへ　転げて\n\nどつこいしよひよこ",
      "characters": 57,
      "ruby": []
    },
    {
      "pageNumber": 54,
      "content": "ひよこのお家は\n\nよいお家\n\n朝からぽかぽか\n\n日があたる\n\nコツココツコと\n\n親鶏が\n\nひよこを呼び呼び\n\n遊びます\n\nひよこはピヨピヨ",
      "characters": 69,
      "ruby": []
    },
    {
      "pageNumber": 55,
      "content": "親鶏の\n\n背中へあがつて\n\n遊んだり\n\n羽根の蔭から\n\n間から\n\n首を出したり\n\n隠したり\n\nひよこは毎日\n\n親鶏と",
      "characters": 58,
      "ruby": []
    },
    {
      "pageNumber": 56,
      "content": "元気に楽しく\n\n遊びます雲雀と蛙",
      "characters": 16,
      "ruby": []
    },
    {
      "pageNumber": 57,
      "content": "雲雀《ひばり》と蛙の\n\n鳴きくらだ\n\n雲雀が負けたら\n\nお空から\n\nピーチク　チクチク\n\n逃げて来る\n\n蛙も負けたら\n\n田甫《たんぼ》から\n\nゲコゲコ　ゲツコと",
      "characters": 80,
      "ruby": []
    },
    {
      "pageNumber": 58,
      "content": "逃げて来る\n\nどつちも負けずに\n\nうんと鳴け\n\n雲雀はどうやら\n\n負けさうだ\n\n蛙もどうやら\n\n負けさうだ\n\nどつちも鳴きくら\n\nくたびれるドンドンバシ",
      "characters": 76,
      "ruby": []
    },
    {
      "pageNumber": 59,
      "content": "ドンドン　バシノ\n\nシタニハ\n\nメダカガ　オヨイデ\n\nアソンデ　ヰル\n\nドンドンバシヲ\n\nトホルト\n\nメダカガ　ミンナデ\n\nニゲテ　イツタ\n\nドンドン　バシヲ",
      "characters": 79,
      "ruby": []
    },
    {
      "pageNumber": 60,
      "content": "ワタルト\n\nドンドンドント\n\nナルカラ\n\nメダカガ\n\nタマゲルノダ子守唄",
      "characters": 36,
      "ruby": []
    },
    {
      "pageNumber": 61,
      "content": "遠くの遠くの\n\n竹山に\n\n露から生れた\n\nお姫さま\n\n姿もやさしく\n\nきりようよし\n\nつづれの錦の\n\n帯をしめ\n\n着物は振り袖",
      "characters": 63,
      "ruby": []
    },
    {
      "pageNumber": 62,
      "content": "一重褄《ひとえづま》\n\n模様は桜の\n\n花ちらし\n\n小笹のお舟に\n\n帆をかけて\n\n黄金のお鈴を\n\n振りながら\n\nねんねする子を\n\nたづねます",
      "characters": 69,
      "ruby": []
    },
    {
      "pageNumber": 63,
      "content": "お舟に積んでる\n\nお土産は\n\n金銀珊瑚《さんご》の\n\nよいおもちや\n\nこの子のお好きな\n\nものばかり燕と柳",
      "characters": 53,
      "ruby": []
    },
    {
      "pageNumber": 64,
      "content": "柳の下から\n\n燕が水汲む\n\n柳の下には\n\n小川が流れる\n\n小川の中から\n\nすいすい汲みます\n\nお嘴《くち》で汲むから\n\nお翼《はね》がぬれます\n\n燕のお家は",
      "characters": 78,
      "ruby": []
    },
    {
      "pageNumber": 65,
      "content": "軒端の蔭です\n\n軒端の蔭から\n\nすいすい出て来る\n\n柳の下から\n\n飛び飛び汲みます\n\nお嘴で汲むから\n\nお翼がぬれます田植",
      "characters": 61,
      "ruby": []
    },
    {
      "pageNumber": 66,
      "content": "今朝から田植が\n\nはじまつた\n\n一枚植ゑれば\n\nまたつぎへ\n\nつぎからつぎへと\n\n植ゑてゆく\n\nひろい田甫《たんぼ》の\n\nすみまでも\n\n日のくれごろには",
      "characters": 76,
      "ruby": []
    },
    {
      "pageNumber": 67,
      "content": "残りなく\n\nみんな青田に\n\nなつてゆく蛙の幼稚園",
      "characters": 24,
      "ruby": []
    },
    {
      "pageNumber": 68,
      "content": "お池は蛙の\n\n幼稚園\n\n毎日泳ぎの\n\n稽古です\n\nバッチヤ　バッチヤ\n\nザンブ　ザンブ\n\nシユシユ　シユ\n\n一番上手に\n\nずんずんと",
      "characters": 66,
      "ruby": []
    },
    {
      "pageNumber": 69,
      "content": "泳ぐは蛙の\n\n先生です\n\nバッチヤ　バッチヤ\n\nザンブ　ザンブ\n\nシユシユ　シユ\n\n泳ぎの出来ない\n\n子蛙に\n\n泳ぎを教へて\n\nゐるのです",
      "characters": 69,
      "ruby": []
    },
    {
      "pageNumber": 70,
      "content": "バッチヤ　バッチヤ\n\nザンブ　ザンブ\n\nシユシユ　シユ燕の泥ぬり",
      "characters": 32,
      "ruby": []
    },
    {
      "pageNumber": 71,
      "content": "燕のお家《うち》は\n\n泥の家\n\n田甫《たんぼ》の泥土\n\nはこんだり\n\nお堀の泥土\n\nはこんだり\n\nお口で壁ぬり\n\nいたします\n\n忙がし　忙がし",
      "characters": 71,
      "ruby": []
    },
    {
      "pageNumber": 72,
      "content": "ピイチク　チー\n\nお口も　よごれて\n\n泥だらけ\n\nお花が咲いても\n\nいきません\n\nせつせと　お家を\n\nつくります目高",
      "characters": 58,
      "ruby": []
    },
    {
      "pageNumber": 73,
      "content": "大きい　目高は\n\n隊長さん\n\nツンツク　ツクツク\n\nツンツンツン\n\n小さい　目高は\n\n兵隊さん\n\n負けずに　ツクツク\n\nツンツンツン\n\nどんなに　この川",
      "characters": 76,
      "ruby": []
    },
    {
      "pageNumber": 74,
      "content": "深かろが\n\nどんなに　流れが\n\n早かろが\n\n目高だ　目高だ\n\n行列だ\n\nツンツン　ツクツク\n\nツンツンツン螢",
      "characters": 54,
      "ruby": []
    },
    {
      "pageNumber": 75,
      "content": "ほたるは　たんぼで\n\nひかります\n\nほたるの　ひかりは\n\nぴつかりこ\n\nぴつかり　ぴつかり\n\nぴつかりこ\n\nほたるは　とんで\n\nすういすうい　にげる\n\nたんぼの　たのなかすういすうい沼の鮒釣り",
      "characters": 96,
      "ruby": []
    },
    {
      "pageNumber": 76,
      "content": "銀鮒　金鮒\n\n沼の鮒沼の鮒釣り",
      "characters": 15,
      "ruby": []
    },
    {
      "pageNumber": 77,
      "content": "面白い\n\n釣竿かついで\n\n友達と\n\n田甫《たんぼ》の釣道\n\nエッサッサ\n\n大鮒　小鮒が\n\n寄つて来る\n\n沼の縁でも\n\nよく釣れる",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 78,
      "content": "今日もにこにこ\n\n元気よく沼の鮒釣りエッサッサ螢狩り螢　来い　来いここへ　来い\n\n田甫《たんぼ》は　泥田で\n\nいかれない\n\n泥田の田甫は\n\n飛んで　来い螢　来い　来い",
      "characters": 83,
      "ruby": []
    },
    {
      "pageNumber": 79,
      "content": "ここへ　来い\n\n川が　深くて\n\nいかれない\n\n川が深くば\n\n飛んで　来いどんと波",
      "characters": 40,
      "ruby": []
    },
    {
      "pageNumber": 80,
      "content": "どんと波来い\n\n沖から来い\n\n遠くの沖から\n\nつづいて来い\n\n大波　小波で\n\n仲よく来い\n\n来い来い来い\n\nどんと波来い\n\nどんと波どん",
      "characters": 68,
      "ruby": []
    },
    {
      "pageNumber": 81,
      "content": "どんどんどん\n\n道草しないで\n\n急いで来い\n\n仲よく陸《をか》見て\n\nどんどと来い\n\n来い来い来い\n\nどんと波来いオハナ　バタケ",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 82,
      "content": "タカイ　トホクノ\n\nオヤマニハ\n\nオハナ　バタケガ\n\nアルノ　デス\n\nオハナ　バタケニ\n\nサクハナハ\n\nナツヲ　マツテテ\n\nサキマシタ\n\nアカヤ　キイロヤ",
      "characters": 77,
      "ruby": []
    },
    {
      "pageNumber": 83,
      "content": "モモイロヤ\n\nシロヤ　シボリヤ\n\nムラサキヤ\n\nミンナ　ミゴトナ\n\nハナ　デシタお風呂",
      "characters": 43,
      "ruby": []
    },
    {
      "pageNumber": 84,
      "content": "お風呂が　沸いた\n\nもう沸いた\n\nおもちやの　金魚が\n\n浮いてゐる\n\n一匹　二匹\n\n三　四　匹\n\n金魚と一緒に\n\nはいりませう\n\nおもちやの　金魚は",
      "characters": 74,
      "ruby": []
    },
    {
      "pageNumber": 85,
      "content": "面白い\n\n沈めてやつても\n\n浮きあがり\n\n泳げといつても\n\n泳がない\n\nお風呂に　並んで\n\n遊んでるお星さん空で　ピカピカお星さん",
      "characters": 65,
      "ruby": []
    },
    {
      "pageNumber": 86,
      "content": "あれあれ　お目々が\n\n光ります\n\n空の　上から\n\n遠くまで\n\n毎晩　寝ないで\n\n見てゐます\n\n小さい　お星は\n\nねむいから\n\nお目々が　ぽちぽち",
      "characters": 72,
      "ruby": []
    },
    {
      "pageNumber": 87,
      "content": "するのです\n\nそれでも　やつぱり\n\nねむらずに\n\nお目々を　こすつて\n\n起きてますお池つくり",
      "characters": 46,
      "ruby": []
    },
    {
      "pageNumber": 88,
      "content": "夏はお庭で\n\n父さんと\n\nお池こさえて\n\n遊びませう\n\nお庭掘つたら\n\n真つ先きに\n\n裏の井戸から\n\n父さんと\n\n水をバケツで",
      "characters": 63,
      "ruby": []
    },
    {
      "pageNumber": 89,
      "content": "運びませう\n\nざんぶざんぶと\n\n涼しそに\n\n水がお池に\n\nたまつたら\n\n金魚いかして\n\n眺めませう海",
      "characters": 50,
      "ruby": []
    },
    {
      "pageNumber": 90,
      "content": "海は　青くて\n\nきれいです\n\n海を　眺めて\n\nをりますと\n\n夏でも　凉しく\n\nなるのです\n\n海は　広くて\n\n愉快です\n\n波と　波とが",
      "characters": 66,
      "ruby": []
    },
    {
      "pageNumber": 91,
      "content": "どんどん　と\n\n負《まけ》ずに　駈けくら\n\nいたしますささぶね",
      "characters": 31,
      "ruby": []
    },
    {
      "pageNumber": 92,
      "content": "ささの　はつぱの\n\nささぶねは\n\n川を　ながれて\n\nいきました\n\n川は　うみまで\n\nつづきます\n\nなみも　うみには\n\nうつてます\n\nろもない　ほもない",
      "characters": 75,
      "ruby": []
    },
    {
      "pageNumber": 93,
      "content": "ささぶねは\n\nどこまで　ながれて\n\nいくのでせうすつぽん亀の子註　＊満洲国の河。外蒙古と内蒙古の国境が北へ向かつて興安嶺につき当つた辺から東へ流れ出してゐます。下流は有名な松花江であります。\n\n児河（ドルガ）＊の亀の子\n\nスツポン　ポンすつぽん亀の子ピツチヤ　ピチヤ\n\nピチヤ　ピチヤ　首出せ\n\nスツポン　ポンすつぽん亀の子",
      "characters": 162,
      "ruby": []
    },
    {
      "pageNumber": 94,
      "content": "泥だらけ\n\n泥から　匍ひ出す\n\nスツポン　ポン\n\n児河の泥水\n\nピツチヤ　ピチヤ夕立夕立　駈あし　早いあし",
      "characters": 53,
      "ruby": []
    },
    {
      "pageNumber": 95,
      "content": "出て来た　出て来た　入道雲\n\n忽《たちま》ち　お空に　ひろがつて\n\n見る間に　降り出す　強い雨\n\n鳴り出す　鳴り出す　光り出す\n\nピカピカ　ゴロゴロ　稲光り\n\n忽ち　お空を　駈けぬけて\n\n早いぞ　早いぞ　入道雲螢と露",
      "characters": 108,
      "ruby": []
    },
    {
      "pageNumber": 96,
      "content": "空のお星が\n\n落ちて来て\n\n蛍の　光に\n\nなつたとサ\n\n蛍の　光は\n\nすいすいと\n\n夜露を　たづねて\n\n飛んでます\n\n夜露も　空の",
      "characters": 65,
      "ruby": []
    },
    {
      "pageNumber": 97,
      "content": "お星から\n\n草の葉　木の葉に\n\n降るのです\n\n螢も　お星を\n\n忘れずに\n\n夜露を　たづねて\n\n飛んでます七夕",
      "characters": 54,
      "ruby": []
    },
    {
