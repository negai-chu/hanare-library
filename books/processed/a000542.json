  "content": [
    {
      "pageNumber": 1,
      "content": "貧しき信徒",
      "characters": 5,
      "ruby": [],
      "displayType": "book-title"
    },
    {
      "pageNumber": 2,
      "content": "母の瞳《ひとみ》",
      "characters": 8,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 3,
      "content": "　ゆうぐれ\n\n瞳をひらけば\n\nふるさとの母うえもまた\n\nとおくみひとみをひらきたまいて\n\nかわゆきものよといいたもうここちするなり",
      "characters": 65,
      "ruby": []
    },
    {
      "pageNumber": 4,
      "content": "お月見",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 5,
      "content": "月に照らされると\n\n月のひかりに\n\nこころがうたれて\n\n芋《いも》の洗ったのや\n\nすすきや豆腐《とうふ》をならべたくなる\n\nお月見だお月見だとさわぎたくなる",
      "characters": 78,
      "ruby": []
    },
    {
      "pageNumber": 6,
      "content": "花がふってくると思う",
      "characters": 10,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 7,
      "content": "花がふってくると思う",
      "characters": 10,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 8,
      "content": "花がふってくるとおもう\n\nこの　てのひらにうけとろうとおもう",
      "characters": 30,
      "ruby": []
    },
    {
      "pageNumber": 9,
      "content": "涙",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 10,
      "content": "つまらないから\n\nあかるい陽《ひ》のなかにたってなみだを\n\nながしていた",
      "characters": 36,
      "ruby": []
    },
    {
      "pageNumber": 11,
      "content": "秋",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 12,
      "content": "こころがたかぶってくる\n\nわたしが花のそばへいって咲けといえば\n\n花がひらくとおもわれてくる",
      "characters": 46,
      "ruby": []
    },
    {
      "pageNumber": 13,
      "content": "光",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 14,
      "content": "ひかりとあそびたい\n\nわらったり\n\n哭《な》いたり\n\nつきとばしあったりしてあそびたい",
      "characters": 43,
      "ruby": []
    },
    {
      "pageNumber": 15,
      "content": "母をおもう",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 16,
      "content": "けしきが\n\nあかるくなってきた\n\n母をつれて\n\nてくてくあるきたくなった\n\n母はきっと\n\n重吉よ重吉よといくどでもはなしかけるだろう",
      "characters": 66,
      "ruby": []
    },
    {
      "pageNumber": 17,
      "content": "風が鳴る",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 18,
      "content": "とうもろこしに風が鳴る\n\n死ねよと　鳴る\n\n死ねよとなる\n\n死んでゆこうとおもう",
      "characters": 40,
      "ruby": []
    },
    {
      "pageNumber": 19,
      "content": "こどもが病《や》む",
      "characters": 9,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 20,
      "content": "こどもが　せきをする\n\nこのせきを癒《なお》そうとおもうだけになる\n\nじぶんの顔が\n\n巨《おお》きな顔になったような気がして\n\nこどもの上に掩《おお》いかぶさろうとする",
      "characters": 84,
      "ruby": []
    },
    {
      "pageNumber": 21,
      "content": "ひびいてゆこう",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 22,
      "content": "おおぞらを\n\nびんびんと　ひびいてゆこう",
      "characters": 20,
      "ruby": []
    },
    {
      "pageNumber": 23,
      "content": "美しくすてる",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 24,
      "content": "菊の芽《め》をとり\n\nきくの芽をすてる\n\nうつくしくすてる",
      "characters": 29,
      "ruby": []
    },
    {
      "pageNumber": 25,
      "content": "美しくみる",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 26,
      "content": "わたしの\n\nかたわらにたち\n\nわたしをみる",
      "characters": 21,
      "ruby": []
    },
    {
      "pageNumber": 27,
      "content": "美しくみる",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 28,
      "content": "路《みち》",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 29,
      "content": "路をみれば\n\nこころ　おどる",
      "characters": 14,
      "ruby": []
    },
    {
      "pageNumber": 30,
      "content": "かなかな",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 31,
      "content": "かなかなが　鳴く\n\nこころは\n\nむらがりおこり\n\nやがて　すべられて\n\nひたすらに　幼《おさな》く　澄む",
      "characters": 52,
      "ruby": []
    },
    {
      "pageNumber": 32,
      "content": "山吹",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 33,
      "content": "山吹を　おもえば\n\n水のごとし",
      "characters": 15,
      "ruby": []
    },
    {
      "pageNumber": 34,
      "content": "ある日",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 35,
      "content": "こころ\n\nうつくしき日は\n\nやぶれたるを\n\nやぶれたりとなせど　かなしからず\n\n妻を　よび\n\n児《こ》をよびて\n\nかたりたわむる",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 36,
      "content": "憎しみ",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 37,
      "content": "にくしみに\n\n花さけば\n\nこころ　おどらん",
      "characters": 21,
      "ruby": []
    },
    {
      "pageNumber": 38,
      "content": "夜",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 39,
      "content": "夜になると\n\nからだも心もしずまってくる\n\n花のようなものをみつめて無造作《むぞうさ》にすわっている",
      "characters": 50,
      "ruby": []
    },
    {
      "pageNumber": 40,
      "content": "日が沈む",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 41,
      "content": "日はあかるいなかへ沈んではゆくが\n\nみている私《わたし》の胸をうってしずんでゆく",
      "characters": 40,
      "ruby": []
    },
    {
      "pageNumber": 42,
      "content": "果物《くだもの》",
      "characters": 8,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 43,
      "content": "秋になると\n\n果物はなにもかも忘れてしまって\n\nうっとりと実《み》のってゆくらしい",
      "characters": 41,
      "ruby": []
    },
    {
      "pageNumber": 44,
      "content": "壁",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 45,
      "content": "秋だ\n\n草はすっかり色づいた\n\n壁のところへいって\n\nじぶんのきもちにききいっていたい",
      "characters": 43,
      "ruby": []
    },
    {
      "pageNumber": 46,
      "content": "赤い寝衣《ねまき》",
      "characters": 9,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 47,
      "content": "湯あがりの桃子は赤いねまきを着て\n\nおしゃべりしながら\n\nふとんのあたりを跳《は》ねまわっていた\n\nまっ赤《か》なからだの上したへ手と足とがとびだして\n\nくるっときりょうのいい顔をのせ\n\nひょこひょこおどっていたが\n\nもうしずかな障子《しょうじ》のそばへねむっている",
      "characters": 133,
      "ruby": []
    },
    {
      "pageNumber": 48,
      "content": "私",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 49,
      "content": "ながいこと病《や》んでいて\n\nふと非常に気持がよいので\n\n人の見てないとこでふざけてみた",
      "characters": 44,
      "ruby": []
    },
    {
      "pageNumber": 50,
      "content": "奇蹟《きせき》",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 51,
      "content": "癩病《らいびょう》の男が\n\n基督《キリスト》のところへ来て拝《おが》んでいる\n\n旦那《だんな》\n\nおめえ様が癒《なお》してやってくれべいとせえ思やあ\n\nわしの病気ゃすぐ癒りまさあ\n\n旦那なおしておくんなせい\n\n拝むから　旦那　癒してやっておくんなせい　旦那\n\n基督は悲しいお顔をなさった\n\nそしてその男のからだへさわって",
      "characters": 160,
      "ruby": []
    },
    {
      "pageNumber": 52,
      "content": "よし　さあ潔《きよ》くなれ\n\nとお言いになると\n\n見ているまに癩病が癒った",
      "characters": 37,
      "ruby": []
    },
    {
      "pageNumber": 53,
      "content": "花",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 54,
      "content": "おとなしくして居《い》ると\n\n花花が咲くのねって　桃子が言う",
      "characters": 30,
      "ruby": []
    },
    {
      "pageNumber": 55,
      "content": "冬",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 56,
      "content": "木に眼《め》が生《な》って人を見ている",
      "characters": 19,
      "ruby": []
    },
    {
      "pageNumber": 57,
      "content": "不思議《ふしぎ》",
      "characters": 8,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 58,
      "content": "こころが美しくなると\n\nそこいらが\n\n明るく　かるげになってくる\n\nどんな不思議がうまれても\n\nおどろかないとおもえてくる\n\nはやく\n\n不思議がうまれればいいなあとおもえてくる",
      "characters": 88,
      "ruby": []
    },
    {
      "pageNumber": 59,
      "content": "人形",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 60,
      "content": "ねころんでいたらば\n\nうまのりになっていた桃子が\n\nそっとせなかへ人形をのせていってしまった\n\nうたをうたいながらあっちへいってしまった\n\nそのささやかな人形のおもみがうれしくて\n\nはらばいになったまま\n\n胸をふくらませてみたりつぼめたりしていた",
      "characters": 123,
      "ruby": []
    },
    {
      "pageNumber": 61,
      "content": "美しくあるく",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 62,
      "content": "こどもが\n\nせっせっ　せっせっ　とあるく\n\nすこしきたならしくあるく\n\nそのくせ\n\nときどきちらっとうつくしくなる",
      "characters": 57,
      "ruby": []
    },
    {
      "pageNumber": 63,
      "content": "悲しみ",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 64,
      "content": "かなしみと\n\nわたしと\n\n足をからませて　たどたどとゆく",
      "characters": 28,
      "ruby": []
    },
    {
      "pageNumber": 65,
      "content": "草をむしる",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 66,
      "content": "草をむしれば\n\nあたりが　かるくなってくる\n\nわたしが\n\n草をむしっているだけになってくる",
      "characters": 45,
      "ruby": []
    },
    {
      "pageNumber": 67,
      "content": "童《こども》",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 68,
      "content": "ちいさい童が\n\nむこうをむいてとんでゆく\n\nたもとを両手でひろげて　かけてゆく\n\nみていたらば\n\nわくわくと　たまらなくなってきた",
      "characters": 65,
      "ruby": []
    },
    {
      "pageNumber": 69,
      "content": "雨の日",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 70,
      "content": "雨が　すきか\n\nわたしはすきだ\n\nうたを　うたおう",
      "characters": 25,
      "ruby": []
    },
    {
      "pageNumber": 71,
      "content": "蟻《あり》",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 72,
      "content": "蟻のごとく\n\nふわふわふわ　とゆくべきか\n\nおおいなる蟻はかるくゆく",
      "characters": 34,
      "ruby": []
    },
    {
      "pageNumber": 73,
      "content": "大山とんぼ",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 74,
      "content": "大山とんぼを　知ってるか\n\nくろくて　巨《おお》きくて　すごいようだ\n\nきょう\n\n昼　ひなか\n\nくやしいことをきいたので\n\n赤んぼを抱《だ》いてでたらば\n\n大山とんぼが　路《みち》にうかんでた\n\nみし　みし　とあっちへゆくので\n\nわたしもぐんぐんくっついていった",
      "characters": 131,
      "ruby": []
    },
    {
      "pageNumber": 75,
      "content": "虫",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 76,
      "content": "虫が鳴いてる\n\nいま　ないておかなければ\n\nもう駄目《だめ》だというふうに鳴いてる\n\nしぜんと\n\n涙がさそわれる",
      "characters": 56,
      "ruby": []
    },
    {
      "pageNumber": 77,
      "content": "あさがお",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 78,
      "content": "あさがおを　見\n\n死をおもい\n\nはかなきことをおもい",
      "characters": 26,
      "ruby": []
    },
    {
      "pageNumber": 79,
      "content": "萩《はぎ》",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 80,
      "content": "萩がすきか\n\nわたしはすきだ\n\n持って　遊ぼうか",
      "characters": 24,
      "ruby": []
    },
    {
      "pageNumber": 81,
      "content": "西瓜《すいか》を喰《く》おう",
      "characters": 14,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 82,
      "content": "西瓜をくおう\n\n西瓜のことをかんがえると\n\nそこだけ明るく　光ったようにおもわれる\n\nはやく　喰おう",
      "characters": 50,
      "ruby": []
    },
    {
      "pageNumber": 83,
      "content": "こうじん虫",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 84,
      "content": "ふと\n\nとって　投げた\n\nこうじんむしをみていたらば\n\nそのせなかは青く\n\nはかないきもちになってしまった",
      "characters": 53,
      "ruby": []
    },
    {
      "pageNumber": 85,
      "content": "春",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 86,
      "content": "桃子\n\nお父《とう》ちゃんはね\n\n早く快《よ》くなってお前と遊びたいよ",
      "characters": 35,
      "ruby": []
    },
    {
      "pageNumber": 87,
      "content": "春",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 88,
      "content": "雀《すずめ》をみていると\n\n私《わたし》は雀になりたくなった",
      "characters": 30,
      "ruby": []
    },
    {
      "pageNumber": 89,
      "content": "陽遊《かげろう》",
      "characters": 8,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 90,
      "content": "さすがにもう春だ\n\n気持も\n\nとりとめの無いくらいゆるんできた\n\nでも彼処《あそこ》にふるえながらたちのぼる\n\n陽遊のような我慢しきれぬおもいもある",
      "characters": 74,
      "ruby": []
    },
    {
      "pageNumber": 91,
      "content": "春",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 92,
      "content": "ほんとによく晴れた朝だ\n\n桃子は窓をあけて首をだし\n\n桃ちゃん　いい子　いい子うよ\n\n桃ちゃん　いい子　いい子うよって歌っている",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 93,
      "content": "梅",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 94,
      "content": "梅を見にきたらば\n\nまだ少ししか咲いていず\n\nこまかい枝がうすうす光っていた",
      "characters": 38,
      "ruby": []
    },
    {
      "pageNumber": 95,
      "content": "冬の夜",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 96,
      "content": "おおひどい風\n\nもう子供等《ら》はねている\n\n私《わたし》は吸入器を組み立ててくれる妻のほうをみながら\n\nほんとに早く快《よ》くなりたいと思った",
      "characters": 72,
      "ruby": []
    },
    {
      "pageNumber": 97,
      "content": "病気",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 98,
      "content": "からだが悪いので\n\n自分のまわりが\n\nぐるっと薄くなったようでたよりなく\n\n桃子をそばへ呼んで話しをしていた",
      "characters": 54,
      "ruby": []
    },
    {
      "pageNumber": 99,
      "content": "太陽",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 100,
      "content": "日をまともに見ているだけで\n\nうれしいと思っているときがある",
      "characters": 30,
      "ruby": []
    },
    {
      "pageNumber": 101,
      "content": "石",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 102,
      "content": "ながい間からだが悪るく\n\nうつむいて歩いてきたら\n\n夕陽《ゆうひ》につつまれたひとつの小石がころがっていた",
      "characters": 53,
      "ruby": []
    },
    {
      "pageNumber": 103,
      "content": "春",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 104,
      "content": "原へねころがり\n\nなんにもない空を見ていた",
      "characters": 21,
      "ruby": []
    },
    {
      "pageNumber": 105,
      "content": "春",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 106,
      "content": "朝眼《め》を醒《さ》まして\n\n自分のからだの弱いこと\n\n妻のこと子供達の行末《ゆくすえ》のことをかんがえ\n\nぼろぼろ涙が出てとまらなかった",
      "characters": 69,
      "ruby": []
    },
    {
      "pageNumber": 107,
      "content": "春",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 108,
      "content": "黒い犬が\n\nのっそり縁側《えんがわ》のとこへ来て私《わたし》を見ている",
      "characters": 35,
      "ruby": []
    },
    {
      "pageNumber": 109,
      "content": "桜",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 110,
      "content": "綺麗な桜の花をみていると\n\nそのひとすじの気持ちにうたれる",
      "characters": 29,
      "ruby": []
    },
    {
      "pageNumber": 111,
      "content": "神の道",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 112,
      "content": "自分が\n\nこの着物さえも脱《ぬ》いで\n\n乞食《こじき》のようになって\n\n神の道にしたがわなくてもよいのか\n\nかんがえの末は必ずここへくる",
      "characters": 68,
      "ruby": []
    },
    {
      "pageNumber": 113,
      "content": "冬",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 114,
      "content": "悲しく投げやりな気持でいると\n\nものに驚かない\n\n冬をうつくしいとだけおもっている",
      "characters": 41,
      "ruby": []
    },
    {
      "pageNumber": 115,
      "content": "冬日《ふゆび》",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 116,
      "content": "冬の日はうすいけれど\n\n明るく\n\n涙も出なくなってしまった私《わたし》をいたわってくれる",
      "characters": 44,
      "ruby": []
    },
    {
      "pageNumber": 117,
      "content": "森",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 118,
      "content": "日がひかりはじめたとき\n\n森のなかをみていたらば\n\n森の中に祭のように人をすいよせるものをかんじた",
      "characters": 49,
      "ruby": []
    },
    {
      "pageNumber": 119,
      "content": "夕焼",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 120,
      "content": "あの夕焼のしたに\n\n妻や桃子たちも待っているだろうと\n\n明るんだ道をたのしく帰ってきた",
      "characters": 43,
      "ruby": []
    },
    {
      "pageNumber": 121,
      "content": "霜《しも》",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 122,
      "content": "地はうつくしい気持をはりきって耐《こ》らえていた\n\nその気持を草にも花にも吐《は》けなかった\n\nとうとう肉をみせるようにはげしい霜をだした",
      "characters": 69,
      "ruby": []
    },
    {
      "pageNumber": 123,
      "content": "冬",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 124,
      "content": "葉は赤くなり\n\nうつくしさに耐《た》えず落ちてしまった\n\n地はつめたくなり\n\n霜をだして死ぬまいとしている",
      "characters": 53,
      "ruby": []
    },
    {
      "pageNumber": 125,
      "content": "日をゆびさしたい",
      "characters": 8,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 126,
      "content": "うすら陽《び》の空をみれば\n\n日のところがあかるんでいる\n\nその日をゆびさしたくなる\n\n心はむなしく日をゆびさしたくなる",
      "characters": 60,
      "ruby": []
    },
    {
      "pageNumber": 127,
      "content": "雨",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 128,
      "content": "窓をあけて雨をみていると\n\nなんにも要《い》らないから\n\nこうしておだやかなきもちでいたいとおもう",
      "characters": 49,
      "ruby": []
    },
    {
      "pageNumber": 129,
      "content": "くろずんだ木",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 130,
      "content": "くろずんだ木をみあげると\n\nむこうではわたしをみおろしている\n\nおまえはまた懐手《ふところで》しているのかといってみおろしている",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 131,
      "content": "障子《しょうじ》",
      "characters": 8,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 132,
      "content": "あかるい秋がやってきた\n\nしずかな障子のそばへすりよって\n\nおとなしい子供のように\n\nじっとあたりのけはいをたのしんでいたい",
      "characters": 62,
      "ruby": []
    },
    {
      "pageNumber": 133,
      "content": "桐《きり》の木",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 134,
      "content": "桐の木がすきか\n\nわたしはすきだ\n\n桐の木んとこへいこうか",
      "characters": 29,
      "ruby": []
    },
    {
      "pageNumber": 135,
      "content": "ひかる人",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 136,
      "content": "私《わたし》をぬぐうてしまい\n\nそこのとこへひかるような人をたたせたい",
      "characters": 35,
      "ruby": []
    },
    {
      "pageNumber": 137,
      "content": "木",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 138,
      "content": "はっきりと\n\nもう秋だなとおもうころは\n\n色色なものが好きになってくる\n\nあかるい日なぞ\n\n大きな木のそばへ行っていたいきがする",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 139,
      "content": "お化け",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 140,
      "content": "冬は\n\n夜になると\n\nうっすらした気持になる\n\nお化けでも出そうな気がしてくる",
      "characters": 39,
      "ruby": []
    },
    {
      "pageNumber": 141,
      "content": "踊《おどり》",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 142,
      "content": "冬になって\n\nこんな静かな日はめったにない\n\n桃子をつれて出たらば\n\n櫟林《くぬぎばやし》のはずれで\n\n子供はひとりでに踊りはじめた\n\n両手をくくれた顎《あご》のあたりでまわしながら\n\n毛糸の真紅《しんく》の頭巾《ずきん》をかぶって首をかしげ\n\nしきりにひょこんひょこんやっている\n\nふくらんで着こんだ着物に染めてある",
      "characters": 159,
      "ruby": []
    },
    {
      "pageNumber": 143,
      "content": "鳳凰《ほうおう》の赤い模様があかるい\n\nきつく死をみつめた私《わたし》のこころは\n\n桃子がおどるのを見てうれしかった",
      "characters": 58,
      "ruby": []
    },
    {
      "pageNumber": 144,
      "content": "素朴《そぼく》な琴《こと》",
      "characters": 13,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 145,
      "content": "この明るさのなかへ\n\nひとつの素朴な琴をおけば\n\n秋の美くしさに耐えかね\n\n琴はしずかに鳴りいだすだろう",
      "characters": 52,
      "ruby": []
    },
    {
      "pageNumber": 146,
      "content": "響《ひびき》",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 147,
      "content": "秋はあかるくなりきった\n\nこの明るさの奥に\n\nしずかな響があるようにおもわれる",
      "characters": 39,
      "ruby": []
    },
    {
      "pageNumber": 148,
      "content": "霧",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 149,
      "content": "霧がみなぎっている\n\nあさ日はあがったらしい\n\nつつましく心はたかぶってくる",
      "characters": 38,
      "ruby": []
    },
    {
      "pageNumber": 150,
      "content": "故郷《ふるさと》",
      "characters": 8,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 151,
      "content": "心のくらい日に\n\nふるさとは祭のようにあかるんでおもわれる",
      "characters": 29,
      "ruby": []
    },
    {
      "pageNumber": 152,
      "content": "こども",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 153,
      "content": "丘《おか》があって\n\nはたけが　あって\n\nほそい木が\n\nひょろひょろっと　まばらにはえてる\n\nまるいような\n\n春の　ひるすぎ\n\nきたないこどもが\n\nくりくりと\n\nめだまをむいて　こっちをみてる",
      "characters": 96,
      "ruby": []
    },
    {
      "pageNumber": 154,
      "content": "豚《ぶた》",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 155,
      "content": "この　豚だって\n\nかわいいよ\n\nこんな　春だもの\n\nいいけしきをすって\n\nむちゅうで　あるいてきたんだもの",
      "characters": 53,
      "ruby": []
    },
    {
      "pageNumber": 156,
      "content": "犬",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 157,
      "content": "もじゃもじゃの　犬が\n\n桃子の\n\nうんこを　くってしまった",
      "characters": 29,
      "ruby": []
    },
    {
      "pageNumber": 158,
      "content": "柿《かき》の葉",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 159,
      "content": "柿の葉は　うれしい\n\n死んでもいいといってるふうな\n\nみずからを無《な》みする\n\nその　ようすがいい",
      "characters": 50,
      "ruby": []
    },
    {
      "pageNumber": 160,
      "content": "涙",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 161,
      "content": "めを　つぶれば\n\nあつい\n\nなみだがでる",
      "characters": 20,
      "ruby": []
    },
    {
      "pageNumber": 162,
      "content": "雲",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 163,
      "content": "あの　雲は　くも\n\nあのまつばやしも　くも\n\nあすこいらの\n\nひとびとも\n\n雲であればいいなあ",
      "characters": 47,
      "ruby": []
    },
    {
      "pageNumber": 164,
      "content": "お銭《あし》",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 165,
      "content": "さびしいから\n\nお銭を　いじくってる",
      "characters": 18,
      "ruby": []
    },
    {
      "pageNumber": 166,
      "content": "水や草は　いい方方《かたがた》である",
      "characters": 18,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 167,
      "content": "はつ夏の\n\nさむいひかげに田圃《たんぼ》がある\n\nそのまわりに\n\nちさい　ながれがある\n\n草が　水のそばにはえてる\n\nみいんな　いいかたがたばかりだ\n\nわたしみたいなものは\n\n顔がなくなるようなきがした",
      "characters": 101,
      "ruby": []
    },
    {
      "pageNumber": 168,
      "content": "天",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 169,
      "content": "天というのは\n\nあたまのうえの\n\nみえる　あれだ\n\n神さまが\n\nおいでなさるなら　あすこだ\n\nほかにはいない",
      "characters": 54,
      "ruby": []
    },
    {
      "pageNumber": 170,
      "content": "秋のひかり",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 171,
      "content": "ひかりがこぼれてくる\n\n秋のひかりは地におちてひろがる\n\nこのひかりのなかで遊ぼう",
      "characters": 41,
      "ruby": []
    },
    {
      "pageNumber": 172,
      "content": "月",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 173,
      "content": "月にてらされると\n\nひとりでに遊びたくなってくる\n\nそっと涙をながしたり\n\nにこにこしたりしておどりたくなる",
      "characters": 54,
      "ruby": []
    },
    {
      "pageNumber": 174,
      "content": "かなしみ",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 175,
      "content": "かなしみを乳房《ちぶさ》のようにまさぐり\n\nかなしみをはなれたら死のうとしている",
      "characters": 40,
      "ruby": []
    },
    {
      "pageNumber": 176,
      "content": "ふるさとの川",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 177,
      "content": "ふるさとの川よ\n\nふるさとの川よ\n\nよい音《おと》をたててながれているだろう",
      "characters": 38,
      "ruby": []
    },
    {
      "pageNumber": 178,
      "content": "ふるさとの山",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 179,
      "content": "ふるさとの山をむねにうつし\n\nゆうぐれをたのしむ",
      "characters": 24,
      "ruby": []
    },
    {
      "pageNumber": 180,
      "content": "顔",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 181,
      "content": "どこかに\n\n本当に気にいった顔はないのか\n\nその顔をすたすたっと通りぬければ\n\nじつにいい世界があるような気がする",
      "characters": 57,
      "ruby": []
    },
    {
      "pageNumber": 182,
      "content": "夕焼",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 183,
      "content": "いま日が落ちて\n\n赤い雲がちらばっている\n\n桃子と往還《おうかん》のところでながいこと見ていた",
      "characters": 47,
      "ruby": []
    },
    {
      "pageNumber": 184,
      "content": "冬の夜",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 185,
      "content": "皆《みんな》が遊ぶような気持でつきあえたら\n\nそいつが一番たのしかろうとおもえたのが気にいって\n\n火鉢の灰を均《な》らしてみた",
      "characters": 63,
      "ruby": []
    },
    {
      "pageNumber": 186,
      "content": "麗日《れいじつ》",
      "characters": 8,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 187,
      "content": "桃子\n\nまた外へ出て\n\n赤い茨《いばら》の実《み》をとって来ようか",
      "characters": 33,
      "ruby": []
    },
    {
      "pageNumber": 188,
      "content": "冬",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 189,
      "content": "ながいこと考えこんで\n\nきれいに諦《あきら》めてしまって外へ出たら\n\n夕方ちかい樺色《かばいろ》の空が\n\nつめたくはりつめた\n\n雲の間《あいだ》に見えてほんとにうれしかった",
      "characters": 86,
      "ruby": []
    },
    {
      "pageNumber": 190,
      "content": "冬の野",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 191,
      "content": "死ぬことばかり考えているせいだろうか\n\n枯れた茅《かや》のかげに\n\n赤いようなものを見たとおもった",
      "characters": 49,
      "ruby": []
    },
    {
      "pageNumber": 192,
      "content": "病床無題",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 193,
      "content": "人を殺すような詩はないか",
      "characters": 12,
      "ruby": []
    },
    {
      "pageNumber": 194,
      "content": "無題",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 195,
      "content": "息吹き返させる詩はないか",
      "characters": 12,
      "ruby": []
    },
    {
      "pageNumber": 196,
      "content": "無題",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 197,
      "content": "ナーニ　死ぬものかと\n\n児《こ》の髪の毛をなぜてやった",
      "characters": 27,
      "ruby": []
    },
    {
      "pageNumber": 198,
      "content": "無題",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 199,
      "content": "赤いシドメのそばへ\n\nにょろにょろと\n\n青大将を考えてみな",
      "characters": 29,
      "ruby": []
    },
    {
      "pageNumber": 200,
      "content": "梅",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 201,
      "content": "眼《め》がさめたように\n\n梅にも梅自身の気持がわかって来て\n\nそう思っているうちに花が咲いたのだろう\n\nそして\n\n寒い朝霜《しも》ができるように\n\n梅自《みず》からの気持がそのまま香《におい》にもなるのだろう",
      "characters": 104,
      "ruby": []
    },
    {
      "pageNumber": 202,
      "content": "雨",
      "characters": 1,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 203,
      "content": "雨は土をうるおしてゆく\n\n雨というもののそばにしゃがんで\n\n雨のすることをみていたい",
      "characters": 42,
      "ruby": []
    },
    {
      "pageNumber": 204,
      "content": "木枯《こがらし》",
      "characters": 8,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 205,
      "content": "風はひゅうひゅう吹いて来て\n\nどこかで静まってしまう",
      "characters": 26,
      "ruby": []
    },
    {
      "pageNumber": 206,
      "content": "無題",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 207,
      "content": "雪がふっているとき\n\n木の根元をみたら\n\n面白《おもしろ》い小人《こびと》がふざけているような気がする",
      "characters": 51,
      "ruby": []
    },
    {
      "pageNumber": 208,
      "content": "無題",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 209,
      "content": "神様　あなたに会いたくなった",
      "characters": 14,
      "ruby": []
    },
    {
      "pageNumber": 210,
      "content": "無題",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 211,
      "content": "夢の中の自分の顔と言うものを始めて見た\n\n発熱がいく日《にち》もつづいた夜\n\n私《わたし》はキリストを念じてねむった\n\n一つの顔があらわれた\n\nそれはもちろん\n\n現在の私の顔でもなく\n\n幼《おさ》ない時の自分の顔でもなく\n\nいつも心にえがいている\n\n最も気高《けだか》い天使の顔でもなかった",
      "characters": 145,
      "ruby": []
    },
    {
      "pageNumber": 212,
      "content": "それよりももっとすぐれた顔であった\n\nその顔が自分の顔であるということはおのずから分った\n\n顔のまわりは金色《きんいろ》をおびた暗黒であった\n\n翌朝《よくちょう》眼《め》がさめたとき\n\n別段熱は下《さが》っていなかった\n\nしかし不思議《ふしぎ》に私の心は平らかだった",
      "characters": 133,
      "ruby": []
    }
  ]
}