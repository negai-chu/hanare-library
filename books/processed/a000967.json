  "content": [
    {
      "pageNumber": 1,
      "content": "蛇の花嫁",
      "characters": 4,
      "ruby": [],
      "displayType": "book-title"
    },
    {
      "pageNumber": 2,
      "content": "しろきもの",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 3,
      "content": "しろきもの",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 4,
      "content": "　ゆくりなく　心のうへをただよへり\n\nながるるひまもなく\n\nあはきがなかに　なほあはき\n\nかすかなる　鳥の啼音《なきね》のつらなれり",
      "characters": 66,
      "ruby": []
    },
    {
      "pageNumber": 5,
      "content": "ほのあをき貝",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 6,
      "content": "ほのあをき貝をもて\n\nわがただよへる心を　をさめよ\n\nらうたけし　ほのあをき貝をもて\n\nわがかなしみを　をさめよ",
      "characters": 56,
      "ruby": []
    },
    {
      "pageNumber": 7,
      "content": "相見ざる日",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 8,
      "content": "こころ　おもくして\n\nうなだれてのみ　あるものを\n\n身をつつむ　ひぐらし色のこゑ",
      "characters": 40,
      "ruby": []
    },
    {
      "pageNumber": 9,
      "content": "さだかならぬ姿",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 10,
      "content": "ありなしの　すがたなればや\n\nきみみえず\n\nうすきひかりの　ながれきて\n\nわがながしめを　よびいづる",
      "characters": 50,
      "ruby": []
    },
    {
      "pageNumber": 11,
      "content": "うたの心",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 12,
      "content": "あめは　こずゑのなかにあり\n\nうたはざる　歌のこころの\n\nゆふぐれに　ときめけり",
      "characters": 40,
      "ruby": []
    },
    {
      "pageNumber": 13,
      "content": "秋の日はうすくして",
      "characters": 9,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 14,
      "content": "秋の日は　うすくして\n\n衣に透《す》けり\n\n秋の日は\n\nみえざるごとく　とほくして\n\n思ひのかげを　うごかせり",
      "characters": 55,
      "ruby": []
    },
    {
      "pageNumber": 15,
      "content": "二人静",
      "characters": 3,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 16,
      "content": "汝《な》がこゑは\n\n月の夜《よ》にゆるる\n\n二人静《ふたりしづか》のはな",
      "characters": 36,
      "ruby": []
    },
    {
      "pageNumber": 17,
      "content": "心のかげのこゑ",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 18,
      "content": "ただよひゆくもの\n\nわが心のなかに\n\nただよひゆくは\n\nゆふぐれのひかりをあびて　おとづるる\n\n汝《な》がこころの　かげのこゑ",
      "characters": 63,
      "ruby": []
    },
    {
      "pageNumber": 19,
      "content": "ゆめ",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 20,
      "content": "いづことも　わかねども\n\nそのかたち　わすれがたかり\n\nそのいろの　わすれがたかり\n\n　　　＊\n\nあはあはと　にほひのこれば\n\n絶えせざる　おもひはるけし",
      "characters": 77,
      "ruby": []
    },
    {
      "pageNumber": 21,
      "content": "遠く思はるる日",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 22,
      "content": "汝がすがた　とほくして\n\n空にうつれる葉のごとく\n\nさびしさは　わが胸に波をうがてり",
      "characters": 42,
      "ruby": []
    },
    {
      "pageNumber": 23,
      "content": "すぎし影",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 24,
      "content": "病めるとき\n\n心のなかにすぎゆきし\n\nかげともあらぬ　影のかげ\n\nその　すぎゆきしにほひをば\n\nひそかに　ひそかに\n\nはぐくめり",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 25,
      "content": "ゆふぐれ",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 26,
      "content": "みぞれするかや\n\nこのゆふぐれの日に\n\nこゑもなく\n\nひとびとの　行き交《か》へり",
      "characters": 41,
      "ruby": []
    },
    {
      "pageNumber": 27,
      "content": "しめらへる花",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 28,
      "content": "くれなゐの\n\n花のさきけり\n\n夜《よる》の潮《しほ》　みちくるときに\n\nしめらひの花の\n\nひとつさきけり",
      "characters": 52,
      "ruby": []
    },
    {
      "pageNumber": 29,
      "content": "あをき影",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 30,
      "content": "あはれ　あはれ\n\n眼はとざされて　みづにかくれし\n\nなにものも　みえわかず\n\nひとつ　ひとつ　あをき影あり",
      "characters": 53,
      "ruby": []
    },
    {
      "pageNumber": 31,
      "content": "しろき花",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 32,
      "content": "むなしき　おゆびもて\n\nまさぐれば",
      "characters": 17,
      "ruby": []
    },
    {
      "pageNumber": 33,
      "content": "しろき花　ゆるるがごとし",
      "characters": 12,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 34,
      "content": "暮れなやむ　ゆふぐれのとき",
      "characters": 13,
      "ruby": []
    },
    {
      "pageNumber": 35,
      "content": "ともしびの揺れの如く",
      "characters": 10,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 36,
      "content": "とほき影の　つながりて\n\nこの　あしたの空につたはりくる\n\nきえがての思ひ　うごきぬ\n\nともしびの\n\nたわわなる　ゆれのごとくに",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 37,
      "content": "悲しみは去らず",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 38,
      "content": "かなしみは　かなたへ去らず\n\n日影のごとく　うつろへど\n\nはてしなき　いのちのなかに　たそがるる",
      "characters": 48,
      "ruby": []
    },
    {
      "pageNumber": 39,
      "content": "水に浮く花",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 40,
      "content": "みづのなかに　うかべる花\n\nこゑをはなてり",
      "characters": 21,
      "ruby": []
    },
    {
      "pageNumber": 41,
      "content": "あをきまぼろし",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 42,
      "content": "かぎりなく　ひろごりゆく\n\nあをき手のまぼろし\n\nあをき手のまぼろし\n\nげにもさみしき",
      "characters": 43,
      "ruby": []
    },
    {
      "pageNumber": 43,
      "content": "あをきまぼろし",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 44,
      "content": "うつつなき　花をうがちて\n\nこころむなしく　しらべをおとす",
      "characters": 29,
      "ruby": []
    },
    {
      "pageNumber": 45,
      "content": "小鳥の如き溜息",
      "characters": 7,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 46,
      "content": "ほのほは　あをき水にぬれ\n\nかたちを消して\n\nそことなく　みだれつつあり\n\nああ　しろき小鳥のごとき溜息は\n\n時の彼方《かなた》に　たたずめり",
      "characters": 71,
      "ruby": []
    },
    {
      "pageNumber": 47,
      "content": "千鳥ぞ啼けり",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 48,
      "content": "わが胸に　千鳥ぞ啼けり\n\nこのゆふぐれに\n\nきみのけはひの　ちかければ",
      "characters": 35,
      "ruby": []
    },
    {
      "pageNumber": 49,
      "content": "ふたたび見むことを",
      "characters": 9,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 50,
      "content": "ああ\n\nふたたび汝《なれ》を見むことを\n\nせちにねがへり\n\nかの秋の日の\n\n芙蓉に似たるすがたをば\n\nふたたび　われにみせよかし\n\nながあめに　ぬれてうなだるる　しだり花かも\n\nかよわなる　汝《な》がおもだちよ\n\nみづいろあをの　かほばせよふたたび汝《なれ》をみむことを",
      "characters": 135,
      "ruby": []
    },
    {
      "pageNumber": 51,
      "content": "過ぐるもの",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 52,
      "content": "あたたかき　秋の日のゆふべなり\n\nこころは　石のうへにすわりて\n\nとどめがたきものの　すぐるをききわけつ\n\nおもてをふせて\n\n掌《て》のなかに　夢をゑがきぬ\n\nしろき夢を",
      "characters": 85,
      "ruby": []
    },
    {
      "pageNumber": 53,
      "content": "ひとつの花",
      "characters": 5,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 54,
      "content": "こずゑのうへに\n\nひとつの花あり\n\nそのいろは　あはくして\n\nひかりのごとく\n\n地にむかひて　うなだれたり",
      "characters": 53,
      "ruby": []
    },
    {
      "pageNumber": 55,
      "content": "春のあをさに",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 56,
      "content": "ひらかざる　花のおもわに身をなげて\n\nこのながながし　病気《いたつき》の\n\nなやみの刺《とげ》をぬぎすてむ\n\n薄氷《うすらひ》の溶くる春のあをさに",
      "characters": 73,
      "ruby": []
    },
    {
      "pageNumber": 57,
      "content": "白き芥子の花",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 58,
      "content": "わがおもひのいづみ\n\nかのひとは　しろき芥子《けし》の花のごとく\n\nひとすぢの　みちのうへにうかべり\n\nはてしなきゆふべの　つながりきたる\n\nひとすぢの\n\nいとほそき　みちのうへに　にほひつつあり",
      "characters": 98,
      "ruby": []
    },
    {
      "pageNumber": 59,
      "content": "さびしさ",
      "characters": 4,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 60,
      "content": "みしらざる　にほひの花よ\n\nいづこにありや\n\nついばみの鳥　あらざるまへに\n\nみしらざる　にほひの花よ",
      "characters": 51,
      "ruby": []
    },
    {
      "pageNumber": 61,
      "content": "真実",
      "characters": 2,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 62,
      "content": "汝がほのかなる　ことのはを\n\nわれはきく\n\nもゆる火のごとく",
      "characters": 30,
      "ruby": []
    },
    {
      "pageNumber": 63,
      "content": "形なき影をもとめて",
      "characters": 9,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 64,
      "content": "かたちなき　かげをもとめて\n\nさだめなく　暮るるならむか\n\nみちのべに　雨はあり\n\nみちのべに　みぞれあり",
      "characters": 53,
      "ruby": []
    },
    {
      "pageNumber": 65,
      "content": "汝がこゑの美しさ",
      "characters": 8,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 66,
      "content": "汝《な》がこゑの　したたる露\n\n汝がこゑの　ただよふ香《にほひ》\n\n汝がこゑの　ゆらめくひかり\n\n汝がこゑの　ひらく花びら\n\n汝がこゑの　ちらばふ星\n\n汝がこゑの　こぼるる蜜\n\n汝がこゑの　くれなゐのつぼみの瓊《たま》\n\n汝がこゑの　みどりの風\n\n汝がこゑの　春の糸雨《いとさめ》",
      "characters": 140,
      "ruby": []
    },
    {
      "pageNumber": 67,
      "content": "汝がこゑの　銀色《ぎん》の衣《きぬ》ずれ\n\n汝がこゑの　いぢらしき君影草《きみかげさう》\n\n汝がこゑの　夢をつつむ雛罌粟《ひなげし》の花\n\n汝がこゑの　黄色《きん》の耳飾り\n\n汝がこゑの　宵のくちべに\n\n汝がこゑの　水面《みのも》の浮鳥\n\n汝がこゑの　揚羽の蝶の朝の舞\n\n汝がこゑの　水晶色の鈴のおとづれ\n\n汝がこゑの　うすあをき月草の物思ひ",
      "characters": 171,
      "ruby": []
    },
    {
      "pageNumber": 68,
      "content": "汝がこゑの　うまるる雛鳩\n\n汝がこゑの\n\n雪色の　心のこゑのうるはしさ",
      "characters": 35,
      "ruby": []
    },
    {
      "pageNumber": 69,
      "content": "うまれざる花",
      "characters": 6,
      "ruby": [],
      "displayType": "section-title"
    },
    {
      "pageNumber": 70,
      "content": "うまれざる花を\n\nわれは抱《いだ》けり\n\nこころ　しぐれのなかに\n\nにほひをおぼゆ",
      "characters": 41,
      "ruby": []
    },
    {
