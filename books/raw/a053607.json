    {
      "pageNumber": 2,
      "content": "一詠",
      "characters": 2,
      "ruby": []
    },
    {
      "pageNumber": 3,
      "content": "ゆきはふる\n\nまなつまひるのやまみちに\n\n光るこなゆき\n\nさんらんたりや\n\nわが道心のたなごころ\n\nうすら侘しきたなごころ",
      "characters": 61,
      "ruby": []
    },
    {
      "pageNumber": 4,
      "content": "二詠",
      "characters": 2,
      "ruby": []
    },
    {
      "pageNumber": 5,
      "content": "ひじりのみあし\n\nつめたきみあし\n\nおんかたへやるせなく\n\nかけまつるさうぞくの\n\nしののめのこゆむらさき\n\nいろのあさがほ",
      "characters": 62,
      "ruby": []
    },
    {
      "pageNumber": 6,
      "content": "三詠",
      "characters": 2,
      "ruby": []
    },
    {
      "pageNumber": 7,
      "content": "なみぢのうへを\n\nとほくよりあゆませたまふ\n\nわが主いえすよ\n\nふなべりになみだをながし\n\nいちねん祈願したてまつる\n\nひとの子のわれの身のうへ\n\nおぼるるものはぺてろなり",
      "characters": 86,
      "ruby": []
    },
    {
      "pageNumber": 8,
      "content": "四詠",
      "characters": 2,
      "ruby": []
    },
    {
      "pageNumber": 9,
      "content": "はなをつむ\n\nはなをつむこころはへ\n\nしろがねづくりの靴をはき\n\nみなつきはじめ\n\nくさばなのたねをつむ\n\nたねをつむこころはへ",
      "characters": 64,
      "ruby": []
    },
    {
      "pageNumber": 10,
      "content": "五詠",
      "characters": 2,
      "ruby": []
    },
    {
      "pageNumber": 11,
      "content": "すずめ\n\nすずめ\n\n金のこなふる奧山《おくやま》に\n\nしんじついとしいべにすずめ\n\nすずめ\n\nすずめ\n\nみ山の奧のべに雀",
      "characters": 60,
      "ruby": []
    }
  ]
