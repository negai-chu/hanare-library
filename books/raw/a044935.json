    {
      "pageNumber": 1,
      "content": "うさぎのくだものや",
      "characters": 9,
      "ruby": [],
      "displayType": "book-title"
    },
    {
      "pageNumber": 2,
      "content": "もぅりの\n\nもぅりの木のかげで、\n\nみゝながうさぎのくだものや。\n\nつぶのそろつた\n\nさくらんぼ、\n\nまつかであまい\n\n大西瓜《おほずいくわ》。\n\nやすうり\n\nなげうり",
      "characters": 84,
      "ruby": []
    },
    {
      "pageNumber": 3,
      "content": "大べんきやう。\n\nかわいいぼつちやんは\n\nじてんしやで、\n\nきれいなおぢやうさんは\n\nかごもつて、\n\nさあ　さあ\n\nいらつしやい、\n\nおほやすうり。\n\nめかたはたつぷり",
      "characters": 84,
      "ruby": []
    },
    {
      "pageNumber": 4,
      "content": "まちがひなし、\n\nどこのみせより\n\nおほやすうり。",
      "characters": 25,
      "ruby": []
    }
  ]
}