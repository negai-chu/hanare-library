      "characters": 10,
      "ruby": []
    },
    {
      "pageNumber": 38,
      "content": "十一月十日",
      "characters": 5,
      "ruby": []
    },
    {
      "pageNumber": 39,
      "content": "「板ばさみ」『改造』　十枚\n\n〔欄外に〕七十七信",
      "characters": 24,
      "ruby": []
    },
    {
      "pageNumber": 40,
